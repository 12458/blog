---
import { getCollection } from 'astro:content';
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';

const posts = (await getCollection('posts'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Hello! I'm Shang En</h1>
				<p>I enjoy writing about technology, programming, and life. I'm a Computer Engineering major at Georgia Institute of Technology. I'm passionate about technology and I love to learn new things.</p>
			</section>
			<section class="posts">
				<h2>Posts</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/posts/${post.id}/`}>
								<span class="title">{post.data.title}</span>
								<FormattedDate date={post.data.pubDate} />
							</a>
							{post.data.description && (
								<p class="description">{post.data.description}</p>
							)}
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.intro {
		margin-bottom: 3rem;
	}
	.intro h1 {
		margin-top: 0;
	}
	.intro p {
		color: var(--text-secondary);
		line-height: 1.7;
	}
	.posts h2 {
		margin-top: 0;
		margin-bottom: 1.5rem;
	}
	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.posts li {
		margin-bottom: 1.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}
	.posts li:last-child {
		border-bottom: none;
	}
	.posts a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		text-decoration: none;
		color: var(--text);
	}
	.posts a:hover .title {
		color: var(--accent);
	}
	.posts .title {
		font-weight: 600;
		font-size: 1.1rem;
	}
	.posts time {
		color: var(--text-secondary);
		font-size: 0.875rem;
		white-space: nowrap;
	}
	.description {
		color: var(--text-secondary);
		font-size: 0.9rem;
		margin: 0.25rem 0 0;
	}
</style>
